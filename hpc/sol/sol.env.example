# Copy this file to hpc/sol/sol.env and customize values for your account.
#
# Example:
#   cp hpc/sol/sol.env.example hpc/sol/sol.env
#   nano hpc/sol/sol.env

# Optional account (from `myaccounts`). Leave empty to use default account.
POISONEDRAG_ACCOUNT=""

# SLURM resource defaults
POISONEDRAG_PARTITION="htc"
POISONEDRAG_QOS="public"
POISONEDRAG_TIME="0-04:00:00"
POISONEDRAG_NODES="1"
POISONEDRAG_CPUS_PER_TASK="8"
POISONEDRAG_MEM="64G"
POISONEDRAG_GPUS="1"
POISONEDRAG_GPU_TYPE=""
POISONEDRAG_CONSTRAINT=""

# Runtime environment
POISONEDRAG_MAMBA_MODULE="mamba/latest"
POISONEDRAG_ENV_PATH=".envs/poisonedrag-sol"
POISONEDRAG_CACHE_ROOT="${SCRATCH:-$HOME}/.cache/poisonedrag"
POISONEDRAG_PYTHON_VERSION="3.10"
POISONEDRAG_PYTORCH_CUDA_VERSION="12.1"
POISONEDRAG_PREFETCH_CONTRIEVER="1"
POISONEDRAG_FORCE_RECREATE="0"

# ASR evaluation defaults
POISONEDRAG_DATASETS="nq hotpotqa msmarco"
POISONEDRAG_NUM_QUESTIONS="10"
POISONEDRAG_NUM_REPEATS="10"
POISONEDRAG_SEED="42"
POISONEDRAG_MODEL_NAME="palm2"
POISONEDRAG_MODEL_CONFIG_PATH="model_configs/palm2_config.json"
POISONEDRAG_EVAL_MODEL_CODE="contriever"
POISONEDRAG_TOP_K="5"
POISONEDRAG_ADV_PER_QUERY="5"
POISONEDRAG_SCORE_FUNCTION="dot"
POISONEDRAG_GPU_ID="0"
POISONEDRAG_RANDOM_TARGETS="True"
POISONEDRAG_REUSE_TARGETS_PER_REPEAT="True"
POISONEDRAG_RESUME="True"
POISONEDRAG_TIMEOUT_SEC="0"
POISONEDRAG_QUERY_RESULTS_DIR="asr_eval"
POISONEDRAG_OUTPUT_DIR="results/asr_evaluation"

# API key option for palm2/gemini:
# - Preferred: export GENAI_API_KEY in your shell before quickstart/submit
# - Optional: place key here (less secure)
POISONEDRAG_GENAI_API_KEY=""
